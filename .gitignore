# =============================================================================
# FactorLab .gitignore
# =============================================================================
# Rule of thumb: nothing in version control that's regenerable, large, or secret.
# Data files, credentials, virtual envs, build artifacts → all out.
# =============================================================================

# ---- Secrets & credentials --------------------------------------------------
.env
.env.*
# !.env.example
*.pem
*.key
auth/
secrets/
credentials/
.upstox_token
.eodhd_token
*_token.txt
*_credentials.json
data/upstox/.token
data/upstox/.auth_code

# ---- Data files (NEVER commit raw or processed data) ------------------------
data/
datasets/
raw/
processed/
snapshots/
exports/
downloads/
pdf_store/
pdfs/
*.csv
*.tsv
*.parquet
*.feather
*.arrow
*.h5
*.hdf5
*.json.gz
*.pkl
*.pickle
*.db
*.sqlite
*.sqlite3
*.duckdb
# Allow small example/test fixtures
!tests/fixtures/**/*.csv
!tests/fixtures/**/*.json
!tests/fixtures/**/*.parquet
!docs/**/*.csv

# ---- Database ---------------------------------------------------------------
postgres-data/
pgdata/
*.dump
*.sql.gz
backups/

# ---- Logs -------------------------------------------------------------------
logs/
*.log
*.log.*
log/

# ---- Python -----------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ---- Virtual environments ---------------------------------------------------
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# ---- Testing & coverage -----------------------------------------------------
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/
nosetests.xml

# ---- Type checking ----------------------------------------------------------
.mypy_cache/
.pyright/
.pytype/
.dmypy.json
dmypy.json
.ruff_cache/

# ---- Jupyter ----------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb_checkpoints
profile_default/
ipython_config.py

# Notebook outputs are usually noise; uncomment if desired:
# *.ipynb

# ---- IDE / editors ----------------------------------------------------------
.idea/
.vscode/
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
*.swp
*.swo
*~
.project
.pydevproject
.spyderproject
.spyproject
.ropeproject

# ---- OS ---------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ---- Alembic / migrations (commit migrations, not autogenerated state) ------
alembic/versions/__pycache__/

# ---- Outputs / artifacts ----------------------------------------------------
artifacts/
results/
runs/
mlruns/
wandb/
output/
outputs/
plots/
figures/
*.png
*.jpg
*.jpeg
*.pdf
# Allow docs imagery if you commit any
!docs/**/*.png
!docs/**/*.jpg
!docs/**/*.pdf

# ---- Compute / cache --------------------------------------------------------
.cache/
.local/
.tmp/
tmp/
temp/

# ---- Claude / AI tooling state ----------------------------------------------
.claude/
.claude-flow/

# ---- Playground (local scratch/test, never commit) --------------------------
playground/

# ---- Personal notes ---------------------------------------------------------
arjun_notes.txt

# ---- Concept / reference PDFs (per memory: do not edit, but should they ship?)
# Decision pending — uncomment to keep concept PDF out of git
# concepts/*.pdf
